# GenAI GitLab Chatbot - Environment Variables
# Copy to .env and fill in your keys.

# ----- LLM (choose one) -----
# LLM_PROVIDER=bytez
LLM_PROVIDER=openai
# LLM_PROVIDER=google
# LLM_PROVIDER=huggingface

# Bytez (if LLM_PROVIDER=bytez) - OpenAI-compatible API from bytez.com
# BYTEZ_API_KEY=...
# BYTEZ_API_BASE=https://api.bytez.com/models/v2/openai/v1
# BYTEZ_MODEL=Qwen/Qwen3-4B

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (if LLM_PROVIDER=google)
GOOGLE_API_KEY=...
GOOGLE_MODEL=gemini-1.5-flash

# HuggingFace (if LLM_PROVIDER=huggingface)
# HUGGINGFACE_API_KEY=...
# HUGGINGFACE_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ----- Embeddings -----
# Options: sentence_transformers (local, no key) | openai | google
EMBEDDINGS_PROVIDER=sentence_transformers
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----- RAG -----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVE=5
SIMILARITY_THRESHOLD=0.5

# ----- Scraper -----
SCRAPE_DELAY_SECONDS=1.0
REQUEST_TIMEOUT=30

# ----- API -----
API_HOST=0.0.0.0
API_PORT=8000
